  INIT -->|init_counter == 12| IDLE
  INIT -->|init_counter != 12| INIT

  IDLE -->|curr_player == 0 && btn_p1_left| MOVE_LEFT_CHECK
  IDLE -->|curr_player == 0 && btn_p1_right| MOVE_RIGHT_CHECK
  IDLE -->|curr_player == 1 && btn_p2_left| MOVE_LEFT_CHECK
  IDLE -->|curr_player == 1 && btn_p2_right| MOVE_RIGHT_CHECK
  IDLE -->|btn_drop| VALIDATE_COL

  MOVE_LEFT_CHECK --> MOVE_LEFT_BRANCH
  MOVE_LEFT_BRANCH -->|rd2 == 1| MOVE_LEFT_WRAP
  MOVE_LEFT_BRANCH -->|rd2 != 1| MOVE_LEFT_DEC
  MOVE_LEFT_DEC --> IDLE
  MOVE_LEFT_WRAP --> IDLE

  MOVE_RIGHT_CHECK --> MOVE_RIGHT_BRANCH
  MOVE_RIGHT_BRANCH -->|rd2 == 1| MOVE_RIGHT_WRAP
  MOVE_RIGHT_BRANCH -->|rd2 != 1| MOVE_RIGHT_INC
  MOVE_RIGHT_INC --> IDLE
  MOVE_RIGHT_WRAP --> IDLE

  VALIDATE_COL --> VALIDATE_COL_BRANCH
  VALIDATE_COL_BRANCH -->|rd2 == 1| IDLE
  VALIDATE_COL_BRANCH -->|rd2 != 1| CALC_COL_OFFSET

  CALC_COL_OFFSET --> CALC_ROW_OFFSET
  CALC_ROW_OFFSET --> COMPUTE_BITMASK
  COMPUTE_BITMASK --> UPDATE_CURR_BOARD
  UPDATE_CURR_BOARD --> UPDATE_MAIN_BOARD
  UPDATE_MAIN_BOARD --> INCREMENT_HEIGHT
  INCREMENT_HEIGHT --> CALC_SCORE
  CALC_SCORE --> CHECK_MOVE_COUNT
  CHECK_MOVE_COUNT --> BRANCH_MOVE_COUNT

  BRANCH_MOVE_COUNT -->|rd2 == 25| WIN_CHECK
  BRANCH_MOVE_COUNT -->|rd2 != 25| SWITCH_PLAYER
  SWITCH_PLAYER --> IDLE

  WIN_CHECK --> WIN_BRANCH_LT
  WIN_BRANCH_LT -->|rd2 == 1| P2_WINS
  WIN_BRANCH_LT -->|rd2 != 1| WIN_CHECK_EQ
  WIN_CHECK_EQ --> WIN_BRANCH_EQ
  WIN_BRANCH_EQ -->|rd2 == 1| DRAW_0
  WIN_BRANCH_EQ -->|rd2 != 1| P1_WINS

  P1_WINS --> GAME_OVER
  P2_WINS --> GAME_OVER
  DRAW_0 --> DRAW_1
  DRAW_1 --> GAME_OVER

  GAME_OVER -->|any button| RESTART_WAIT
  GAME_OVER -->|none| GAME_OVER

  RESTART_WAIT -->|all released| INIT
  RESTART_WAIT -->|not all released| RESTART_WAIT
